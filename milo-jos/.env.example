# =============================================================================
# Variables de entorno — milo-jos.es v2.0
# Copiar a .env y rellenar valores antes de ejecutar.
# NUNCA commitear .env al repositorio.
# =============================================================================

# --- Dominio ---
# Dominio principal del sitio (usado por Caddy y meta tags)
DOMAIN=milo-jos.es

# --- Reflex ---
# Entorno de ejecución: dev | prod
REFLEX_ENV=prod

# --- Deploy (Oracle VPS) ---
# Usuario SSH para deploy
DEPLOY_USER=ubuntu
# IP o hostname del servidor
DEPLOY_HOST=xxx.xxx.xxx.xxx
# Ruta en el servidor donde se clona el repo
DEPLOY_PATH=/opt/milo-jos
